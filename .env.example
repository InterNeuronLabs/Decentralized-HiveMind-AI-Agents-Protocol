# ============================================================
# Orchestrator — required
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/orchestrator

# Redis connection string
REDIS_URL=redis://localhost:6379

# Hex-encoded Ed25519 signing key for the orchestrator (node identity)
# Generate with: openssl rand -hex 32
ORCHESTRATOR_SIGNING_KEY=

# Hex-encoded Ed25519 signing key used for admin API endpoints
# Keep this separate from the orchestrator key
ADMIN_SIGNING_KEY=

# Path to the cluster CA key PEM (used to issue mTLS certs to nodes)
ORCHESTRATOR_CA_KEY_PATH=private/keys/ca.key.pem

# Port the orchestrator HTTP server listens on
PORT=8080

# Deployment environment: development | staging | production
APP_ENV=development

# ============================================================
# Solana (Phase 5 — only required when Solana integration is active)
# ============================================================

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# SPL token program ID for the cluster credit token
CLUSTER_TOKEN_PROGRAM_ID=

# ============================================================
# Node client — required when running node-client
# ============================================================

# URL of the orchestrator
ORCHESTRATOR_URL=https://orchestrator.example.com

# Path to persist the node keypair
WALLET_PATH=~/.node-client/wallet.key

# TLS mutual auth — optional in development, required in production
# Leave blank or unset to use plain HTTPS without client certs
CA_CERT_PATH=
NODE_CERT_PATH=
NODE_KEY_PATH=

# Model to serve (must be in the orchestrator's ALLOWED_MODELS list)
MODEL_ID=llama3-8b

# Path to the local GGUF model file (used with llama-direct feature)
MODEL_PATH=

# Address of a running llama.cpp HTTP server (used without llama-direct feature)
LLAMA_SERVER_URL=http://127.0.0.1:8080

# Node hardware tier: nano | edge | pro | cluster
NODE_TIER=edge

# Optional Solana wallet to receive on-chain credits
SOLANA_WALLET=
