  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, tier, reputation_score, jobs_completed, last_seen_at\n        FROM nodes\n        WHERE is_banned = FALSE\n          AND last_seen_at > NOW() - INTERVAL '5 minutes'\n        ORDER BY reputation_score DESC\n        LIMIT 100\n        ",
